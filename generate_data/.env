# ==========================
# Google Cloud
# ==========================
GCP_PROJECT=transport-analytics-501213
PUBSUB_TOPIC=network_usage_events

# ==========================
# Data Generation
# ==========================
SUBSCRIBER_COUNT=1000
TOWER_COUNT=50

EVENTS_PER_SECOND=10
ERROR_RATE=0.05

# ==========================
# Network Configuration
# ==========================
MIN_SIGNAL_DBM=-110
MAX_SIGNAL_DBM=-60

TECHNOLOGIES=4G,5G

# ==========================
# Runtime
# ==========================
LOG_LEVEL=INFO